# Créer une relation ACTED_IN entre un acteur et un film
def create_relation_acted_in(tx, nom_acteur, nom_film):
    query = """MATCH (p:Person {name: $var1})
               MATCH (m:Movie {title: $var2})
               CREATE (p)-[:ACTED_IN]->(m)"""
    tx.run(query, var1=nom_acteur, var2=nom_film)

with driver.session() as session:
    session.execute_write(create_relation_acted_in, "Jean Dujardin", "The Matrix")

