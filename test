def get_actors(tx):
    query = """MATCH (p:Person)-[:ACTED_IN]-()
               RETURN DISTINCT p.name AS name"""
    result = tx.run(query)
    return result.data()

with driver.session() as session:
    actors = session.execute_read(get_actors)
    for a in actors:
        print(a['name'])

def get_movies(tx, nom_acteur):
    query = """MATCH (p:Person {name: $variable_cypher})-[:ACTED_IN]-(m:Movie)
               RETURN DISTINCT m.title AS title"""
    result = tx.run(query, variable_cypher=nom_acteur)
    return result.data()

with driver.session() as session:
    movies = session.execute_read(get_movies, "Keanu Reeves")
    for m in movies:
        print(m['title'])


# Créer un nouveau nœud Person
def create_actor(tx, nom_acteur):
    tx.run("MERGE (:Person {name: $variable_cypher})", variable_cypher=nom_acteur)

with driver.session() as session:
    session.execute_write(create_actor, "Jean")

