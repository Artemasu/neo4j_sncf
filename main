from neo4j import GraphDatabase
from nettoyage import preparer_donnees

URI = "bolt://52.87.245.146"
AUTH = ("neo4j", "gums-shelf-sewage")

def creer_gares_unique(tx, df_nodes):
    # MERGE sur le code IATA pour garantir l'unicité
    query = "MERGE (g:Gare {code_iata: $iata}) SET g.ville = $nom"
    for _, ligne in df_nodes.iterrows():
        tx.run(query, iata=ligne['iata'], nom=ligne['ville'])

def creer_trajets(tx, df_rels):
    # MATCH pour relier les gares existantes
    query = """
    MATCH (dep:Gare {code_iata: $id_dep})
    MATCH (arr:Gare {code_iata: $id_arr})
    CREATE (dep)-[:TRAJET {
        `n°`: $no,
        `heure départ`: $hd,
        `heure arrivée`: $ha,
        date: $dt
    }]->(arr)
    """
    for _, ligne in df_rels.iterrows():
        tx.run(query, 
               id_dep=ligne['Origine IATA'], id_arr=ligne['Destination IATA'],
               no=ligne['TRAIN_NO'], hd=ligne['Heure_depart'], 
               ha=ligne['Heure_arrivee'], dt=ligne['DATE'])

def recherche_directe(tx, v_dep, v_arr, h_min):
    # Recherche utilisant les noms de propriétés exacts du schéma
    query = """
    MATCH (d:Gare)-[r:TRAJET]->(a:Gare)
    WHERE d.ville = $v_dep AND a.ville = $v_arr AND r.`heure départ` >= $h_min
    RETURN r.`n°` AS train, r.`heure départ` AS dep, r.`heure arrivée` AS arr
    ORDER BY r.`heure départ` ASC
    """
    result = tx.run(query, v_dep=v_dep, v_arr=v_arr, h_min=h_min)
    return result.data()

def main():
    driver = GraphDatabase.driver(URI, auth=AUTH)
    
    # 1. Préparation via le module nettoyage
    df_nodes, df_rels = preparer_donnees('tgvmax.csv')
    
    with driver.session() as session:
        # 2. Nettoyage de la base Neo4j (supprime tout)
        print("Vidage de la base de données...")
        session.run("MATCH (n) DETACH DELETE n")
        
        # 3. Importation en deux étapes (Conseil Prof)
        print(f"Importation de {len(df_nodes)} gares...")
        session.execute_write(creer_gares_unique, df_nodes)
        
        print(f"Importation de {len(df_rels)} trajets...")
        session.execute_write(creer_trajets, df_rels)
        
        # 4. Test de recherche 
        print("\n--- TEST DE RECHERCHE ---")
        print("Note: Respectez les majuscules du fichier CSV (ex: PARIS (intramuros))")
        dep = input("Ville de départ : ")
        arr = input("Ville d'arrivée : ")
        h = input("Heure minimum (ex: 08:00) : ")
        
        resultats = session.execute_read(recherche_directe, dep, arr, h)
        
        if resultats:
            for res in resultats:
                # Utilisation des clés retournées par la requête RETURN
                print(f"Train {res['train']} : {res['dep']} -> {res['arr']}")
        else:
            print("Aucun trajet trouvé.")

    driver.close()

if __name__ == "__main__":
    main()