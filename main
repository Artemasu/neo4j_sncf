import pandas as pd
from neo4j import GraphDatabase
from nettoyage import preparer_donnees 

URI = "bolt://100.55.66.81"
AUTH = ("neo4j", "secrets-primes-weeks")

def configurer_base(session):
    """Crée une contrainte d'unicité pour accélérer les recherches et éviter les doublons."""
    print("Configuration des index (contrainte d'unicité)...")
    session.run("CREATE CONSTRAINT gare_iata IF NOT EXISTS FOR (g:Gare) REQUIRE g.code_iata IS UNIQUE")

def importer_donnees_opti(session, df_nodes, df_rels):
    """Importation massive optimisée avec UNWIND."""
    
    # 1. Import des Gares
    query_nodes = """
    UNWIND $batch AS ligne
    MERGE (g:Gare {code_iata: ligne.iata})
    SET g.ville = ligne.ville
    """
    dict_nodes = df_nodes.to_dict('records')
    session.run(query_nodes, batch=dict_nodes)
    print(f"Importation de {len(df_nodes)} gares terminée.")

    # 2. Import des Trajets par lots (chunks)
    query_rels = """
    UNWIND $batch AS ligne
    MATCH (dep:Gare {code_iata: ligne['Origine IATA']})
    MATCH (arr:Gare {code_iata: ligne['Destination IATA']})
    CREATE (dep)-[:TRAJET {
        `n°`: ligne.TRAIN_NO,
        `heure départ`: ligne.Heure_depart,
        `heure arrivée`: ligne.Heure_arrivee,
        date: ligne.DATE
    }]->(arr)
    """
    
    dict_rels = df_rels.to_dict('records')
    chunk_size = 10000 
    
    print(f"Importation de {len(dict_rels)} trajets...")
    for i in range(0, len(dict_rels), chunk_size):
        batch = dict_rels[i:i + chunk_size]
        session.run(query_rels, batch=batch)
        print(f"Progression : {min(i + chunk_size, len(dict_rels))} / {len(dict_rels)}", end='\r')
    print("\nImportation des trajets terminée.")

def recherche_directe(tx, v_dep, v_arr, h_min):
    """Recherche flexible : accepte 'Paris' pour 'PARIS (intramuros)'."""
    query = """
    MATCH (d:Gare)-[r:TRAJET]->(a:Gare)
    WHERE toUpper(d.ville) CONTAINS toUpper($v_dep) 
      AND toUpper(a.ville) CONTAINS toUpper($v_arr) 
      AND r.`heure départ` >= $h_min
    RETURN r.`n°` AS train, 
           r.`heure départ` AS dep, 
           r.`heure arrivée` AS arr, 
           d.ville AS ville_dep, 
           a.ville AS ville_arr,
           r.date AS dt
    ORDER BY r.date ASC, r.`heure départ` ASC
    LIMIT 15
    """
    result = tx.run(query, v_dep=v_dep, v_arr=v_arr, h_min=h_min)
    return result.data()

def main():
    driver = GraphDatabase.driver(URI, auth=AUTH)
    
    with driver.session() as session:
        # VERIFICATION : Est-ce que la base est déjà remplie ?
        check_query = "MATCH (g:Gare) RETURN count(g) AS nb"
        nb_gares = session.run(check_query).single()["nb"]

        if nb_gares == 0:
            print("Base vide. Préparation et importation des données...")
            df_nodes, df_rels = preparer_donnees('tgvmax.csv')
            configurer_base(session)
            importer_donnees_opti(session, df_nodes, df_rels)
        else:
            print(f"Base déjà alimentée ({nb_gares} gares trouvées).")

        # INTERFACE DE RECHERCHE
        print("\n" + "="*30)
        print("MOTEUR DE RECHERCHE TGVMAX")
        print("="*30)
        
        dep = input("Ville de départ (ex: Paris) : ")
        arr = input("Ville d'arrivée (ex: Lille) : ")
        h = input("Heure minimum (ex: 08:00) : ")
        
        print("\nRecherche en cours...")
        resultats = session.execute_read(recherche_directe, dep, arr, h)
        
        if resultats:
            print(f"{len(resultats)} trajets trouvés (Top 15) :")
            print("-" * 50)
            for res in resultats:
                print(f"[{res['dt']}] Train {res['train']} : {res['dep']} -> {res['arr']}")
                print(f"       Gares : {res['ville_dep']} -> {res['ville_arr']}\n")
        else:
            print("\nAucun trajet trouvé. Vérifiez l'orthographe ou la date des trajets.")

    driver.close()

if __name__ == "__main__":
    main()